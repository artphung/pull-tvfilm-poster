<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🍿 Poster Fetcher</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0e0e10;
    --surface: #18181b;
    --surface2: #232328;
    --border: #2e2e35;
    --text: #f0f0f2;
    --text-muted: #8888a0;
    --accent: #e8c468;
    --accent-dim: rgba(232,196,104,0.12);
    --green: #4ade80;
    --red: #f87171;
    --radius: 10px;
  }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding: 32px 20px;
  }

  header {
    text-align: center;
    margin-bottom: 36px;
  }

  header h1 {
    font-family: 'Instrument Serif', serif;
    font-size: 2rem;
    font-style: italic;
    color: var(--accent);
    letter-spacing: -0.02em;
    margin-bottom: 6px;
  }

  header p {
    font-size: 13px;
    color: var(--text-muted);
  }

  .container {
    max-width: 820px;
    margin: 0 auto;
  }

  /* Search bar */
  .search-row {
    display: flex;
    gap: 8px;
    margin-bottom: 24px;
  }

  .search-row input {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    padding: 11px 14px;
    outline: none;
    transition: border-color 0.15s;
  }

  .search-row input:focus { border-color: var(--accent); }
  .search-row input::placeholder { color: var(--text-muted); }

  .type-toggle {
    display: flex;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .type-toggle button {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    padding: 11px 16px;
    transition: all 0.15s;
  }

  .type-toggle button.active {
    background: var(--accent-dim);
    color: var(--accent);
    font-weight: 600;
  }

  .btn {
    background: var(--accent);
    border: none;
    border-radius: var(--radius);
    color: #0e0e10;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    padding: 11px 20px;
    transition: opacity 0.15s;
    white-space: nowrap;
  }

  .btn:hover { opacity: 0.88; }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .btn-outline {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text);
  }

  .btn-outline:hover { border-color: var(--accent); color: var(--accent); opacity: 1; }

  /* Results grid */
  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 12px;
    margin-bottom: 28px;
  }

  .poster-card {
    background: var(--surface);
    border: 2px solid transparent;
    border-radius: var(--radius);
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.15s, transform 0.15s;
    position: relative;
  }

  .poster-card:hover { transform: translateY(-2px); border-color: var(--border); }
  .poster-card.selected { border-color: var(--accent); }

  .poster-card img {
    width: 100%;
    aspect-ratio: 2/3;
    object-fit: cover;
    display: block;
    background: var(--surface2);
  }

  .poster-card .card-info {
    padding: 8px 10px;
  }

  .poster-card .card-title {
    font-size: 12px;
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .poster-card .card-year {
    font-size: 11px;
    color: var(--text-muted);
  }

  .poster-card .check-badge {
    position: absolute;
    top: 7px;
    right: 7px;
    background: var(--accent);
    color: #0e0e10;
    border-radius: 50%;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    opacity: 0;
    transition: opacity 0.15s;
  }

  .poster-card.selected .check-badge { opacity: 1; }

  /* Match panel */
  .match-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 20px;
  }

  .match-panel h3 {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 14px;
  }

  .notion-entries {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 240px;
    overflow-y: auto;
  }

  .notion-entry {
    align-items: center;
    background: var(--surface2);
    border: 1px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    gap: 12px;
    padding: 10px 14px;
    transition: border-color 0.15s;
  }

  .notion-entry:hover { border-color: var(--border); }
  .notion-entry.selected { border-color: var(--accent); background: var(--accent-dim); }

  .notion-entry .entry-name {
    font-size: 13px;
    font-weight: 500;
    flex: 1;
  }

  .notion-entry .entry-meta {
    font-size: 11px;
    color: var(--text-muted);
  }

  .tag {
    background: var(--surface2);
    border-radius: 4px;
    color: var(--text-muted);
    font-size: 11px;
    padding: 2px 7px;
  }

  /* Preview */
  .preview-row {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 20px;
  }

  .preview-row img {
    width: 100px;
    border-radius: 7px;
    aspect-ratio: 2/3;
    object-fit: cover;
    background: var(--surface2);
    flex-shrink: 0;
  }

  .preview-info { flex: 1; }
  .preview-info .pi-title {
    font-family: 'Instrument Serif', serif;
    font-size: 1.2rem;
    font-style: italic;
    margin-bottom: 4px;
  }
  .preview-info .pi-notion {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 12px;
  }
  .preview-info .pi-notion span { color: var(--accent); font-weight: 500; }

  .preview-actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 4px; }

  /* Log */
  .log {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 20px;
    min-height: 20px;
  }
  .log.success { color: var(--green); }
  .log.error { color: var(--red); }

  /* States */
  .empty-state {
    text-align: center;
    padding: 48px 20px;
    color: var(--text-muted);
    font-size: 13px;
  }

  .spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    vertical-align: middle;
    margin-right: 6px;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .section-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 10px;
  }

  /* Notion search row */
  .notion-search-row {
    display: flex;
    gap: 8px;
    margin-bottom: 10px;
  }

  .notion-search-row input {
    flex: 1;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    padding: 8px 12px;
    outline: none;
  }

  .notion-search-row input:focus { border-color: var(--accent); }
  .notion-search-row input::placeholder { color: var(--text-muted); }

  hr { border: none; border-top: 1px solid var(--border); margin: 24px 0; }
</style>
</head>
<body>
<div class="container">
  <header>
    <h1>🍿 Poster Fetcher</h1>
    <p>Search for a film or series → pick a poster → push it to your Notion page cover</p>
  </header>

  <!-- Step 1: TMDB Search -->
  <div class="section-label">1 — Find a poster</div>
  <div class="search-row">
    <input type="text" id="tmdbSearch" placeholder="e.g. Severance, Dune, The Bear…" />
    <div class="type-toggle">
      <button id="typeMovie" class="active" onclick="setType('movie')">Film</button>
      <button id="typeTV" onclick="setType('tv')">TV</button>
    </div>
    <button class="btn" onclick="searchTMDB()">Search</button>
  </div>

  <div id="tmdbLog" class="log"></div>
  <div id="tmdbResults" class="results-grid"></div>

  <div id="step2" style="display:none">
    <hr>

    <!-- Step 2: Pick Notion entry -->
    <div class="section-label">2 — Match to a Notion entry</div>
    <div class="match-panel">
      <h3>Your Film/Series List</h3>
      <div class="notion-search-row">
        <input type="text" id="notionFilter" placeholder="Filter entries…" oninput="filterEntries()" />
        <button class="btn btn-outline" style="font-size:12px;padding:8px 14px" onclick="loadNotionEntries()">↻ Reload</button>
      </div>
      <div id="notionLog" class="log"></div>
      <div id="notionEntries" class="notion-entries">
        <div class="empty-state">Click "Reload" to load your Notion entries</div>
      </div>
    </div>

    <!-- Step 3: Preview & push -->
    <div id="step3" style="display:none">
      <hr>
      <div class="section-label">3 — Apply to Notion</div>
      <div class="preview-row">
        <img id="previewImg" src="" alt="Poster" />
        <div class="preview-info">
          <div class="pi-title" id="previewTitle"></div>
          <div class="pi-notion">→ <span id="previewNotionName"></span></div>
          <div class="preview-actions">
            <button class="btn" onclick="applyPoster('cover')">Set as page cover</button>
            <button class="btn btn-outline" onclick="applyPoster('both')">Cover + embed in body</button>
          </div>
        </div>
      </div>
      <div id="applyLog" class="log"></div>
    </div>
  </div>
</div>

<script>
const TMDB_KEY = '54880a6f1db77ba73dde2be0d58f358a';
const TMDB_BASE = 'https://api.themoviedb.org/3';
const TMDB_IMG = 'https://image.tmdb.org/t/p/w500';
const NOTION_DB = 'collection://42a33394-f3ac-82e1-97fc-07a172da0a85';

let mediaType = 'movie';
let selectedPoster = null;   // { url, title, year }
let selectedNotion = null;   // { id, name }
let allEntries = [];

function setType(t) {
  mediaType = t;
  document.getElementById('typeMovie').classList.toggle('active', t === 'movie');
  document.getElementById('typeTV').classList.toggle('active', t === 'tv');
}

function log(id, msg, type = '') {
  const el = document.getElementById(id);
  el.className = 'log ' + type;
  el.innerHTML = msg;
}

async function searchTMDB() {
  const q = document.getElementById('tmdbSearch').value.trim();
  if (!q) return;
  log('tmdbLog', '<span class="spinner"></span> Searching TMDB…');
  document.getElementById('tmdbResults').innerHTML = '';
  selectedPoster = null;
  updateStep3();

  try {
    const res = await fetch(`${TMDB_BASE}/search/${mediaType}?api_key=${TMDB_KEY}&query=${encodeURIComponent(q)}&include_adult=false`);
    const data = await res.json();
    const results = (data.results || []).filter(r => r.poster_path).slice(0, 12);

    if (!results.length) {
      log('tmdbLog', 'No results with posters found. Try a different title.', 'error');
      return;
    }

    log('tmdbLog', `Found ${results.length} result${results.length > 1 ? 's' : ''}. Click a poster to select it.`);
    renderPosters(results);
    document.getElementById('step2').style.display = 'block';
    if (!allEntries.length) loadNotionEntries();
  } catch(e) {
    log('tmdbLog', 'TMDB search failed: ' + e.message, 'error');
  }
}

function renderPosters(results) {
  const grid = document.getElementById('tmdbResults');
  grid.innerHTML = '';
  results.forEach(r => {
    const title = r.title || r.name || '';
    const year = (r.release_date || r.first_air_date || '').slice(0, 4);
    const imgUrl = TMDB_IMG + r.poster_path;
    const card = document.createElement('div');
    card.className = 'poster-card';
    card.innerHTML = `
      <div class="check-badge">✓</div>
      <img src="${imgUrl}" alt="${title}" loading="lazy" />
      <div class="card-info">
        <div class="card-title" title="${title}">${title}</div>
        <div class="card-year">${year}</div>
      </div>`;
    card.onclick = () => selectPoster(card, imgUrl, title, year);
    grid.appendChild(card);
  });
}

function selectPoster(card, url, title, year) {
  document.querySelectorAll('.poster-card').forEach(c => c.classList.remove('selected'));
  card.classList.add('selected');
  selectedPoster = { url, title, year };
  updateStep3();
}

// ---- Notion ----

async function loadNotionEntries() {
  log('notionLog', '<span class="spinner"></span> Loading from Notion…');
  document.getElementById('notionEntries').innerHTML = '';
  selectedNotion = null;

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: `You are a Notion API assistant. Query the user's Film/Series Notion database and return ONLY a JSON array of objects with keys: id (the Notion page URL), name (the title), type (Film or TV Series), status. No markdown, no explanation. Just raw JSON array.`,
        messages: [{ role: 'user', content: `Query all entries from Notion database ${NOTION_DB}. Return JSON array only.` }],
        mcp_servers: [{ type: 'url', url: 'https://mcp.notion.com/mcp', name: 'notion-mcp' }]
      })
    });
    const data = await res.json();

    // Extract text from response
    let raw = '';
    for (const block of (data.content || [])) {
      if (block.type === 'text') raw += block.text;
      if (block.type === 'mcp_tool_result') {
        const t = block.content?.[0]?.text || '';
        raw += t;
      }
    }

    // Find JSON array in response
    const match = raw.match(/\[[\s\S]*\]/);
    if (!match) throw new Error('No JSON array in response');
    allEntries = JSON.parse(match[0]);
    log('notionLog', `Loaded ${allEntries.length} entries.`);
    renderEntries(allEntries);
  } catch(e) {
    log('notionLog', 'Failed to load entries: ' + e.message, 'error');
  }
}

function filterEntries() {
  const q = document.getElementById('notionFilter').value.toLowerCase();
  const filtered = q ? allEntries.filter(e => e.name.toLowerCase().includes(q)) : allEntries;
  renderEntries(filtered);
}

function renderEntries(entries) {
  const container = document.getElementById('notionEntries');
  if (!entries.length) {
    container.innerHTML = '<div class="empty-state">No entries found.</div>';
    return;
  }
  container.innerHTML = '';
  entries.forEach(e => {
    const row = document.createElement('div');
    row.className = 'notion-entry' + (selectedNotion?.id === e.id ? ' selected' : '');
    row.innerHTML = `
      <span class="entry-name">${e.name}</span>
      <span class="entry-meta">${e.type || ''}</span>
      <span class="tag">${e.status || ''}</span>`;
    row.onclick = () => selectNotionEntry(row, e);
    container.appendChild(row);
  });
}

function selectNotionEntry(row, entry) {
  document.querySelectorAll('.notion-entry').forEach(r => r.classList.remove('selected'));
  row.classList.add('selected');
  selectedNotion = entry;
  updateStep3();
}

function updateStep3() {
  const step3 = document.getElementById('step3');
  if (!selectedPoster || !selectedNotion) { step3.style.display = 'none'; return; }
  step3.style.display = 'block';
  document.getElementById('previewImg').src = selectedPoster.url;
  document.getElementById('previewTitle').textContent = selectedPoster.title + (selectedPoster.year ? ` (${selectedPoster.year})` : '');
  document.getElementById('previewNotionName').textContent = selectedNotion.name;
  document.getElementById('applyLog').textContent = '';
  document.getElementById('applyLog').className = 'log';
}

async function applyPoster(mode) {
  if (!selectedPoster || !selectedNotion) return;
  log('applyLog', '<span class="spinner"></span> Pushing to Notion…');

  const pageId = selectedNotion.id;
  const imgUrl = selectedPoster.url;

  let prompt = `Update the Notion page at URL "${pageId}":
1. Set the page cover image to this external URL: ${imgUrl}`;

  if (mode === 'both') {
    prompt += `\n2. Also insert an image block at the top of the page body using this URL: ${imgUrl}`;
  }

  prompt += `\nConfirm when done.`;

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: 'You are a Notion assistant. Execute the requested Notion page update exactly as described. Reply with a short confirmation.',
        messages: [{ role: 'user', content: prompt }],
        mcp_servers: [{ type: 'url', url: 'https://mcp.notion.com/mcp', name: 'notion-mcp' }]
      })
    });
    const data = await res.json();

    const text = (data.content || []).filter(b => b.type === 'text').map(b => b.text).join(' ');
    const hadToolUse = (data.content || []).some(b => b.type === 'mcp_tool_use');

    if (hadToolUse || text.toLowerCase().includes('updated') || text.toLowerCase().includes('set') || text.toLowerCase().includes('cover')) {
      log('applyLog', `✓ Cover set on "${selectedNotion.name}". Open Notion to see it.`, 'success');
    } else {
      log('applyLog', 'Response: ' + (text || 'No confirmation received.'));
    }
  } catch(e) {
    log('applyLog', 'Failed: ' + e.message, 'error');
  }
}

// Allow Enter key to trigger search
document.getElementById('tmdbSearch').addEventListener('keydown', e => {
  if (e.key === 'Enter') searchTMDB();
});
</script>
</body>
</html>
